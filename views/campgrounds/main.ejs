<div class="container">

  <header class="jumbotron">
    <div class="container">
      <h1>Campgrounds</h1>
      <h6>View our hand-picked campgrounds all over the world.</h6>
    </div>
  </header>

  <main class="row text-center" style="display:flex; flex-wrap: wrap;">
    <% campgrounds.forEach(campground => { %>
    <div class="col-lg-3 col-md-4 col-sm-6">
      <div class="card">
        <img src="<%= campground.image %>" class="card-img-top" alt="" style="height: 12rem;">
        <div class="card-body">
          <h3 class="card-title"><%= campground.name   %></h3>
          <a href="/campgrounds/<%= campground.id  %>" class="card-link">More Info</a>
        </div>
      </div>
    </div>
    <% }) %>
  </main>


</div>