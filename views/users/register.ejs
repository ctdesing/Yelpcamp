<div class="container">
  <div class="jumbotron" style="max-width: fit-content; margin: 0 auto;">
    <h1 style="margin-bottom: 2rem;">Register</h1>
    <!-- Form -->
    <form action="/users" method="POST">
      <div class="form-group">
        <label for="exampleInputEmail1">Name</label>
        <input type="text" class="form-control" id="name" placeholder="Name" name="name">
      </div>
      <div class="form-group">
        <label for="">User Name</label>
        <input type="text" class="form-control" id="username" placeholder="Username" name="username">
      </div>
      <div class="form-group">
        <label for="exampleInputPassword1">Password</label>
        <input type="password" class="form-control" id="password" placeholder="Password URL" name="password">
      </div>
      <button type="submit" class="btn btn-primary" style="width: max-content;">Submit</button>
    </form>
  </div>
</div>